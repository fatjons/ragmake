# Stateful RAG local defaults
STATEFUL_RAG_PLATFORM=local
STATEFUL_RAG_NAMESPACE=.stateful_rag
STATEFUL_RAG_CORPUS_ID=demo
STATEFUL_RAG_STATE_DIR=.stateful_rag_demo
STATEFUL_RAG_SQLITE_DB_PATH=.stateful_rag_demo/stateful_rag.sqlite
STATEFUL_RAG_TOP_K=5
STATEFUL_RAG_CHUNK_MAX_WORDS=160
STATEFUL_RAG_CHUNK_OVERLAP_WORDS=20

# OpenAI-compatible models
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_DIMENSIONS=

# Azure OpenAI
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_VERSION=YOUR_API_VERSION
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DIMENSIONS=

# Azure Blob Storage and Azure AI Search
AZURE_STORAGE_CONNECTION_STRING=YOUR_AZURE_STORAGE_CONNECTION_STRING
AZURE_STORAGE_CONTAINER=stateful-rag
AZURE_STORAGE_PREFIX=stateful-rag
AZURE_SEARCH_ENDPOINT=https://YOUR-SERVICE.search.windows.net
AZURE_SEARCH_API_KEY=YOUR_AZURE_SEARCH_API_KEY
AZURE_SEARCH_INDEX=stateful-rag
AZURE_SEARCH_VECTOR_FIELD=vector

# Postgres and pgvector
POSTGRES_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME
POSTGRES_ARTIFACT_SCHEMA=public
POSTGRES_ARTIFACT_TABLE=stateful_rag_artifacts
PGVECTOR_DIMENSIONS=1536
PGVECTOR_SCHEMA=public
PGVECTOR_TABLE=stateful_rag_chunks
PGVECTOR_INDEX_METHOD=hnsw

# AWS placeholders for future adapters
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_BUCKET=
AWS_S3_PREFIX=stateful-rag
AWS_BEDROCK_EMBEDDING_MODEL_ID=
AWS_BEDROCK_CHAT_MODEL_ID=
AWS_OPENSEARCH_ENDPOINT=
AWS_RDS_DSN=

# GCP placeholders for future adapters
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_STORAGE_BUCKET=
GCP_STORAGE_PREFIX=stateful-rag
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
VERTEX_AI_EMBEDDING_MODEL=
VERTEX_AI_CHAT_MODEL=
BIGQUERY_DATASET=
ALLOYDB_DSN=
